# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# generated native folders
/ios
/android

# native signing & credentials
.kotlin/
*.orig.*
*.jks
*.keystore
*.p8
*.p12
*.key
*.mobileprovision
*.pem

# native build artifacts
*.ipa
*.apk
*.aab

# environment files & secrets — never commit (see docs/SECURITY.md)
.env
.env.*
!.env.example

# Supabase local dev state (migrations, functions, seed stay committed)
supabase/.temp/
supabase/.branches/

# Metro
.metro-health-check*

# debug & logs
npm-debug.*
yarn-debug.*
yarn-error.*
*.log

# typescript
*.tsbuildinfo

# test coverage
coverage/

# editor & tool local state (.vscode and .claude/settings.json stay committed)
.idea/
.claude/settings.local.json

# macOS
.DS_Store

# transient session state (blocker notes stay committed)
docs/notes/handoff.md

# Cursor local plan files (never commit)
.cursor/plans/

# Task 10 evidence: raw capture sets stay local; GitHub keeps a representative proof set
